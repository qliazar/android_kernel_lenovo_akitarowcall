#
# Focaltech Touchscreen driver configuration
#

config TOUCHSCREENM_FTS
    bool "Focaltechm Touchscreen"
    depends on I2C
    default n
    help
      Say Y here if you have Focaltech touch panel.
      If unsure, say N.
      
config TOUCHSCREENM_FTS_DIRECTORY
    string "Focaltech ts directory name"
    default "focaltechm_touch"
    depends on TOUCHSCREEN_FTS
    
